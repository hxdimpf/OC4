{
    "type": "project",
    "name": "hxdimpf/oc4",
    "license": "GNU General Public License",
    "description": "opencaching.de source code",
    "require": {
        "php": ">=8.2",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "doctrine/doctrine-bundle": "^2.7.0",
        "doctrine/orm": "^3.6",
        "doctrine/doctrine-migrations-bundle": "^3.0",
        "knplabs/knp-menu-bundle": "^3.7",
        "symfony/console": "7.4.*",
        "symfony/dotenv": "7.4.*",
        "symfony/flex": "^2.10.0",
        "symfony/form": "7.4.*",
        "symfony/mailer": "7.4.*",
        "symfony/mime": "7.4.*",
        "symfony/framework-bundle": "7.4.*",
        "symfony/intl": "7.4.*",
        "symfony/monolog-bundle": "^4.0.1",
        "symfony/property-access": "7.4.*",
        "symfony/property-info": "7.4.*",
        "symfony/string": "7.4.*",
        "symfony/translation": "7.4.*",
        "symfony/twig-bundle": "7.4.*",
        "symfony/validator": "7.4.*",
        "symfony/yaml": "7.4.*",
        "twig/twig": "^3.23"
    },
    "require-dev": {
        "symfony/maker-bundle": "^1.66.0",
        "symfony/var-dumper": "^7.4",
        "symfony/web-profiler-bundle": "^7.4",
        "symplify/config-transformer": "^12.4"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": {
            "*": "dist"
        },
        "sort-packages": true,
        "allow-plugins": {
            "symfony/flex": true
        }
    },
    "autoload": {
        "psr-4": {
            "Oc\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Oc\\Tests\\": "tests/"
        }
    },
    "replace": {
        "paragonie/random_compat": "2.*",
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php71": "*",
        "symfony/polyfill-php70": "*",
        "symfony/polyfill-php56": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": "true",
            "require": "7.4.*"
        }
    }
}
