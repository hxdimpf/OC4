{% extends 'app/base.html.twig' %}
{% block title %}OpenCaching{% endblock %}

{% block page_content %}
<div class="oc-home">

  {# Left column #}
  <div class="oc-home-side">

    {# Short card #}
    <div class="card oc-card mb-3">
      <div class="card-header fw-bold">
        <i class="fa-solid fa-bolt me-1"></i> {{ 'Quick access'|trans }}
      </div>
      <div class="card-body d-flex flex-column gap-2">
        <a href="/livemap" class="btn btn-outline-primary w-100 text-start">
          <i class="fa-solid fa-map me-2"></i>{{ 'Live Map'|trans }}
        </a>
        <a href="/caches/" class="btn btn-outline-primary w-100 text-start">
          <i class="fa-solid fa-magnifying-glass me-2"></i>{{ 'Search caches'|trans }}
        </a>
        <a href="/cache/new" class="btn btn-outline-primary w-100 text-start">
          <i class="fa-solid fa-plus me-2"></i>{{ 'Hide a cache'|trans }}
        </a>
      </div>
    </div>

    {# Tall card #}
    <div class="card oc-card">
      <div class="card-header fw-bold">
        <i class="fa-solid fa-circle-question me-1"></i> {{ 'What is geocaching?'|trans }}
      </div>
      <div class="card-body">
        <ul class="oc-steps list-unstyled mb-0">
          <li>
            <span class="oc-step-icon"><i class="fa-solid fa-map-pin"></i></span>
            <div>
              <strong>{{ 'Find'|trans }}</strong>
              <p class="text-secondary mb-0">{{ 'Find a cache near you and navigate by GPS to the coordinates.'|trans }}</p>
            </div>
          </li>
          <li>
            <span class="oc-step-icon"><i class="fa-solid fa-box-archive"></i></span>
            <div>
              <strong>{{ 'Log it'|trans }}</strong>
              <p class="text-secondary mb-0">{{ 'Sign the physical logbook and record your find online.'|trans }}</p>
            </div>
          </li>
          <li>
            <span class="oc-step-icon"><i class="fa-solid fa-star"></i></span>
            <div>
              <strong>{{ 'Hide it'|trans }}</strong>
              <p class="text-secondary mb-0">{{ 'Place your own cache and share your favourite spots with the community.'|trans }}</p>
            </div>
          </li>
          <li>
            <span class="oc-step-icon"><i class="fa-solid fa-users"></i></span>
            <div>
              <strong>{{ 'Get involved'|trans }}</strong>
              <p class="text-secondary mb-0">{{ 'OpenCaching is open, free and entirely community-driven.'|trans }}</p>
            </div>
          </li>
        </ul>
      </div>
    </div>

  </div>

  {# Center column #}
  <div class="oc-home-main">
    <div class="card oc-card h-100">
      <div class="card-body d-flex flex-column align-items-center justify-content-center text-center gap-4 py-5">

        <div>
          <div class="text-center"><span class="badge px-3 py-2 mb-2" style="background:#68a063;font-size:0.85em">PHP / Symfony backend</span></div>
          <p class="text-muted" style="max-width:600px;margin:0.5rem auto 0;font-size:0.85rem">
            This page is served by <strong>OC4</strong>, a PHP/Symfony 7.x frontend.
            It uses Doctrine DBAL (raw SQL, no ORM), Twig templates, and the shared
            <code>oc-frontend</code> submodule. The same frontend JavaScript powers both
            OC4 and OC5 — they share one codebase, two backends, one database.
          </p>
<div class="text-center"><span class="badge px-3 py-2 mb-2" style="background:#68a063;font-size:0.85em">PHP / Symfony backend</span></div>          <p class="text-muted" style="max-width:600px;margin:0.5rem auto 0;font-size:0.85rem">            This page is served by <strong>OC4</strong>, a PHP/Symfony 7.x frontend.            It uses Doctrine DBAL (raw SQL, no ORM), Twig templates, and the shared            <code>oc-frontend</code> submodule. The same frontend JavaScript powers both            OC4 and OC5 — they share one codebase, two backends, one database.          </p>
          <div class="oc-home-subtitle text-secondary">
            {{ 'The open geocaching network — free, open, community-driven.'|trans }}
          </div>
        </div>

        <div class="oc-stats-row">
          <div class="oc-stat">
            <span class="oc-stat-number">{{ cacheCount|number_format(0, ',', '.') }}</span>
            <span class="oc-stat-label">{{ 'Active caches'|trans }}</span>
          </div>
          <div class="oc-stat-divider"></div>
          <div class="oc-stat">
            <span class="oc-stat-number">{{ logCount|number_format(0, ',', '.') }}</span>
            <span class="oc-stat-label">{{ 'Log entries'|trans }}</span>
          </div>
          <div class="oc-stat-divider"></div>
          <div class="oc-stat">
            <span class="oc-stat-number">{{ userCount|number_format(0, ',', '.') }}</span>
            <span class="oc-stat-label">{{ 'Members'|trans }}</span>
          </div>
        </div>

        <div class="d-flex gap-3 flex-wrap justify-content-center">
          <a href="/livemap" class="btn btn-primary btn-lg px-4">
            <i class="fa-solid fa-map me-2"></i>{{ 'To the map'|trans }}
          </a>
          <a href="/caches/" class="btn btn-outline-primary btn-lg px-4">
            <i class="fa-solid fa-magnifying-glass me-2"></i>{{ 'Search caches'|trans }}
          </a>
        </div>

        <p class="text-secondary mb-0 mt-2" style="max-width: 480px; font-size: 0.9rem;">
          {{ 'OpenCaching uses no proprietary map APIs. The live map runs on OpenStreetMap — open, free, no API key required.'|trans }}
        </p>

      </div>
    </div>
  </div>

  {# Right column #}
  <div class="oc-home-side">

    {# Tall card #}
    <div class="card oc-card mb-3">
      <div class="card-header fw-bold">
        <i class="fa-solid fa-shield-halved me-1"></i> {{ 'Why OpenCaching?'|trans }}
      </div>
      <div class="card-body">
        <ul class="list-unstyled oc-why-list mb-0">
          <li><i class="fa-solid fa-check text-success me-2"></i>{{ 'No Google dependency'|trans }}</li>
          <li><i class="fa-solid fa-check text-success me-2"></i>{{ 'Completely free — no premium plans'|trans }}</li>
          <li><i class="fa-solid fa-check text-success me-2"></i>{{ 'Open data, open code'|trans }}</li>
          <li><i class="fa-solid fa-check text-success me-2"></i>{{ 'No tracking, no ads'|trans }}</li>
          <li><i class="fa-solid fa-check text-success me-2"></i>{{ 'GDPR-compliant, servers in Germany'|trans }}</li>
          <li><i class="fa-solid fa-check text-success me-2"></i>{{ 'API for everyone — openly documented'|trans }}</li>
          <li><i class="fa-solid fa-check text-success me-2"></i>{{ 'Dark mode & mobile support'|trans }}</li>
        </ul>
      </div>
    </div>

    {# Short card #}
    <div class="card oc-card">
      <div class="card-body text-center py-4">
        <i class="fa-solid fa-earth-europe fa-2x mb-3" style="color: var(--oc-primary);"></i>
        <p class="mb-0 text-secondary" style="font-size: 0.9rem; line-height: 1.5;">
          {{ 'OpenCaching is part of a worldwide network of independent geocaching platforms.'|trans }}
        </p>
      </div>
    </div>

  </div>

</div>
{% endblock page_content %}
