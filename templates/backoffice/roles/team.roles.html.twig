{% extends 'backoffice/base.html.twig' %}

{% block page_content %}

<h4 class="mb-3">{{ 'The team' | trans }}</h4>

{% if teamAndRoles is defined and teamAndRoles %}
  <div class="d-flex flex-wrap gap-3 mt-2">
    {% for roleName in roleNames | sort((a, b) => a.role) | column('role') %}
      {% set members = teamAndRoles | filter(m => m.role == roleName) %}
      <div class="card oc-card" style="min-width: 220px; max-width: 280px;">
        <div class="card-header fw-semibold" style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em;">
          {{ roleName | replace({'ROLE_': ''}) }}
        </div>
        <ul class="list-group list-group-flush">
          {% for member in members %}
            <li class="list-group-item" style="background: var(--oc-bg-surface); color: var(--oc-text-primary); border-color: var(--oc-border); padding: 0.4rem 0.75rem;">
              {{ member.username }}
              <small class="text-secondary ms-1">#{{ member.user_id }}</small>
            </li>
          {% else %}
            <li class="list-group-item text-secondary" style="background: var(--oc-bg-surface); border-color: var(--oc-border); font-size: 0.85rem; padding: 0.4rem 0.75rem;">—</li>
          {% endfor %}
        </ul>
      </div>
    {% endfor %}
  </div>
{% else %}
  <p class="text-secondary mt-3">{{ 'No team members found' | trans }}.</p>
{% endif %}

{% endblock %}
